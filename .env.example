# Copiá a .env.local y usá el proyecto Supabase de DESARROLLO.
# Guía completa: docs/entornos.md

# development | production  (Vercel: development en rama develop, production en main)
NEXT_PUBLIC_APP_ENV=development

# Supabase DEV → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO_DEV.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_dev

# Login (solo servidor; NO uses NEXT_PUBLIC_ para password/secret)
AUTH_USERNAME="tu@email.com"
AUTH_PASSWORD="tu_contraseña_dev"
AUTH_SECRET=genera_un_string_largo_aleatorio_distinto_a_prod

# Solo en dev: permite npm run db:reset
INVENTARIO_RESET_ALLOWED=true
