# Supabase → Project Settings → API (no uses la URL de "REST" ni Data API)
NEXT_PUBLIC_SUPABASE_URL=https://TU_PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_aqui

# Login hardcodeado (solo servidor; NO uses NEXT_PUBLIC_ para password/secret)
# Usá comillas si hay @ o caracteres especiales
AUTH_USERNAME="tu@email.com"
AUTH_PASSWORD="tu_contraseña"
AUTH_SECRET=genera_un_string_largo_aleatorio
